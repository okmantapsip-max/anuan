local function DoVerify()
    local key = KeyInput.Text:match("^%s*(.-)%s*$")
    if key == "" then
        StatusLbl.Text = "⚠️ Masukkan kode dulu!"
        StatusLbl.TextColor3 = Color3.fromRGB(255,180,40)
        return
    end

    StartLoading()

    task.spawn(function()
        local valid, msg = CheckKey(key)
        StopLoading()

        if valid then
            -- Progress bar ke 100% hijau
            ProgressBar.BackgroundColor3 = Color3.fromRGB(50,200,120)
            TweenService:Create(ProgressBar, TweenInfo.new(0.3), {Size=UDim2.new(1,0,1,0)}):Play()
            SubmitBtn.Text = "✅ Valid!"
            SubmitBtn.BackgroundColor3 = Color3.fromRGB(50,200,120)
