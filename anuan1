-- ============================================================
-- CHAT PARSER (Epic / Legendary / Mythic)
-- ============================================================
local function stripHTML(text)
    text = text:gsub("<[^>]+>","")
    text = text:gsub("&lt;","<"):gsub("&gt;",">"):gsub("&amp;","&")
    return text
end

local chatTierKeys = {
    [4]="EpicEnabled",
    [5]="LegendaryEnabled",
    [6]="MythicEnabled",
}

local recentMessages = {}
local function processMessage(raw)
    if not ScriptActive then return end
    if not raw:find("obtained") then return end
    -- Debounce: skip pesan duplikat dalam 2 detik
    if recentMessages[raw] then return end
    recentMessages[raw] = true
    task.delay(2, function() recentMessages[raw] = nil end)
    local text = stripHTML(raw)

    local player  = text:match("%[Server%]:? (.+) obtained")
    local fullItem = text:match("obtained a[n]? (.+) %(")
    local weight   = text:match("%((.-)%)")
    if not fullItem or not player then return end
    fullItem = fullItem:match("^%s*(.-)%s*$")
    player   = player:match("^%s*(.-)%s*$")
    weight   = weight or "?"

    -- Deteksi mutasi dari prefix
    local detectedMut = nil
    local fishName = fullItem
    local Variants = ReplicatedStorage:FindFirstChild("Variants")
    if Variants then
        for _, mod in pairs(Variants:GetChildren()) do
            local ok2, data = pcall(function() return require(mod) end)
            if ok2 and data and data.Data and data.Data.Name then
                local mutName = data.Data.Name
                if fullItem:sub(1,#mutName+1):upper() == (mutName.." "):upper() then
                    detectedMut = mutName
                    fishName = fullItem:sub(#mutName+2)
                    break
                end
            end
        end
    end

    local playerObj = Players:FindFirstChild(player)
    local userId = playerObj and playerObj.UserId or 0
    local maskedName = MaskName(player)
    local avatarUrl = "https://www.roblox.com/headshot-thumbnail/image?userId="
        ..tostring(userId).."&width=420&height=420&format=png"

    -- ── Cek Secret Fish ──────────────────────────────────────
    local fishAssetId = SecretFishData[fishName] or SecretFishData[fullItem]
    if not fishAssetId then
        -- coba case-insensitive
        for name, id in pairs(SecretFishData) do
            if name:lower() == fishName:lower() or name:lower() == fullItem:lower() then
                fishAssetId = id
                break
            end
        end
    end

    if fishAssetId and Settings.SecretEnabled then
        -- Fetch image URL dari Roblox thumbnails API
        local imageUrl = nil
        pcall(function()
            local res = httpRequest({
                Url="https://thumbnails.roblox.com/v1/assets?assetIds="..tostring(fishAssetId).."&returnPolicy=PlaceHolder&size=420x420&format=Png&isCircular=false",
                Method="GET"
            })
            if res and res.Body then
                local parsed = HttpService:JSONDecode(res.Body)
                if parsed and parsed.data and parsed.data[1] and parsed.data[1].imageUrl then
                    imageUrl = parsed.data[1].imageUrl
                end
            end
        end)
        local mutDisplay = (detectedMut and detectedMut~="") and detectedMut or "N/A"
        local fields = {
            {name="👤 Player",  value="**"..maskedName.."** (@"..maskedName..")", inline=false},
            {name="🐟 Ikan",    value="`"..fishName.."`", inline=true},
            {name="⭐ Rarity",  value="`SECRET`", inline=true},
            {name="⚖️ Berat",  value="`"..weight.."`", inline=true},
            {name="✨ Mutasi",  value="`"..mutDisplay.."`", inline=true},
        }
        local embed = {
            title="WIH ANAK ANJ DAPAT SIKRITTT!!!!",
            color=65431,
            fields=fields,
            thumbnail={url=avatarUrl},
            footer={text="PAN HOOK v2.4 • Fish It"},
            timestamp=os.date("!%Y-%m-%dT%H:%M:%SZ")
        }
        if imageUrl then embed.image = {url=imageUrl} end
        local payload = {
            username="PAN HOOK",
            embeds={embed}
        }
        pcall(function()
            httpRequest({Url=Current_Webhook,Method="POST",
                Headers={["Content-Type"]="application/json"},Body=HttpService:JSONEncode(payload)})
        end)
        Stats.Total=Stats.Total+1
        Stats.Secret=Stats.Secret+1
        if UI_Stats["Total"] then UI_Stats["Total"].Text=tostring(Stats.Total) end
        if UI_Stats["Secret"] then UI_Stats["Secret"].Text=tostring(Stats.Secret) end
        UpdateFishingStatus("✨ "..fishName.." | "..player, true)
        return
    end

    -- ── Cek Ruby Gemstone ─────────────────────────────────────
    if Settings.RubyEnabled and detectedMut and detectedMut:lower()=="gemstone"
        and fishName:lower():find("ruby") then
        local fields = {
            {name="👤 Player", value="**"..maskedName.."** (@"..maskedName..")", inline=false},
            {name="🐟 Ikan",   value="`"..fishName.."`", inline=true},
            {name="⚖️ Berat", value="`"..weight.."`", inline=true},
            {name="🧬 Mutasi", value="`Gemstone`", inline=true},
        }
        local embed = {
            title="💎 Ruby Gemstone!",
            color=0x32DCBC,
            fields=fields,
            thumbnail={url=avatarUrl},
            footer={text="PAN HOOK v2.4 • Fish It"},
            timestamp=os.date("!%Y-%m-%dT%H:%M:%SZ")
        }
        if fishAssetId then
            embed.image={url="https://www.roblox.com/asset-thumbnail/image?assetId="
                ..tostring(fishAssetId).."&width=420&height=420&format=png"}
        end
        local payload={username="PAN HOOK",embeds={embed}}
        pcall(function()
            httpRequest({Url=Current_Webhook,Method="POST",
                Headers={["Content-Type"]="application/json"},Body=HttpService:JSONEncode(payload)})
        end)
        Stats.Total=Stats.Total+1
        Stats.Ruby=Stats.Ruby+1
        if UI_Stats["Total"] then UI_Stats["Total"].Text=tostring(Stats.Total) end
        if UI_Stats["Ruby"] then UI_Stats["Ruby"].Text=tostring(Stats.Ruby) end
        UpdateFishingStatus("💎 Ruby: "..fishName.." | "..player, true)
        return
    end

    -- ── Cek Rarity Epic-Mythic ────────────────────────────────
    local tier = (fishCache and fishCache[fishName]) or (fishCache and fishCache[fullItem])
    if not tier and fishCache then
        for name, t in pairs(fishCache) do
            if name:lower() == fishName:lower() or name:lower() == fullItem:lower() then
                tier = t; break
            end
        end
    end
    if not tier or not chatTierKeys[tier] then return end
    if not Settings[chatTierKeys[tier]] then return end

    local info = rarityInfo[tier]
    local fields = {
        {name="👤 Player", value="**"..maskedName.."**", inline=false},
        {name="🐟 Ikan",   value="`"..fishName.."`", inline=true},
        {name="⭐ Rarity", value="`"..info.name.."`", inline=true},
        {name="⚖️ Berat", value="`"..weight.."`", inline=true},
        {name="✨ Mutasi", value="`"..(detectedMut~="" and detectedMut or "N/A").."`", inline=true},
    }
    local payload = {
        username="PAN HOOK",
        embeds={{
            title="**DAPATNYA AMPAS DEK, MENDING GALER AJA**",
            color=info.color,
            fields=fields,
            thumbnail={url=RARITY_ANIMATED_EMOJI},
            footer={text="PAN HOOK v2.4 • Fish It"},
            timestamp=os.date("!%Y-%m-%dT%H:%M:%SZ")
        }}
    }
    if userId~=0 then payload.embeds[1].author={icon_url=avatarUrl,name=maskedName} end
    pcall(function()
        httpRequest({Url=Current_Webhook,Method="POST",
            Headers={["Content-Type"]="application/json"},Body=HttpService:JSONEncode(payload)})
    end)
    Stats.Total=Stats.Total+1
    if UI_Stats["Total"] then UI_Stats["Total"].Text=tostring(Stats.Total) end
    UpdateFishingStatus(info.name..": "..fishName.." | "..player, true)
end

-- Hook TextChatService
local TextChatService = game:GetService("TextChatService")
if TextChatService then
    TextChatService.OnIncomingMessage = function(msg)
        if not ScriptActive then return end
        processMessage(msg.Text or "")
    end
end

-- Hook chat lama (fallback)
local ChatEvents = ReplicatedStorage:FindFirstChild("DefaultChatSystemChatEvents")
if ChatEvents then
    local OnMsg = ChatEvents:FindFirstChild("OnMessageDoneFiltering")
    if OnMsg then
        table.insert(Connections, OnMsg.OnClientEvent:Connect(function(d)
            if not ScriptActive then return end
            if d and d.Message then processMessage(d.Message) end
        end))
    end
end

-- Hook TextChannels (MessageReceived)
local TextChannels = TextChatService:FindFirstChild("TextChannels")
if TextChannels then
    for _, channel in pairs(TextChannels:GetChildren()) do
        if channel:IsA("TextChannel") then
            table.insert(Connections, channel.MessageReceived:Connect(function(msg)
                if not ScriptActive then return end
                processMessage(msg.Text or "")
            end))
        end
    end
end

