local function CreateMultiDropdown(parent, labelText, itemList, selectedItems, onChanged)
    local Frame=Instance.new("Frame",parent)
    Frame.BackgroundColor3=Theme.Content
    Frame.Size=UDim2.new(1,-4,0,34)
    Frame.BorderSizePixel=0
    AddCorner(Frame,6)
    AddStroke(Frame,Theme.Border,1)

    local Lbl=Instance.new("TextLabel",Frame)
    Lbl.BackgroundTransparency=1
    Lbl.Position=UDim2.new(0,10,0,0)
    Lbl.Size=UDim2.new(0,100,1,0)
    Lbl.Font=Enum.Font.GothamBold
    Lbl.Text=labelText
    Lbl.TextColor3=Theme.TextSecond
    Lbl.TextSize=11
    Lbl.TextXAlignment=Enum.TextXAlignment.Left

    local function countSelected()
        local n=0
        for _,v in pairs(selectedItems) do if v then n=n+1 end end
        return n
    end

    local DropBtn=Instance.new("TextButton",Frame)
    DropBtn.BackgroundColor3=Theme.Input
    DropBtn.Position=UDim2.new(0,110,0.5,-10)
    DropBtn.Size=UDim2.new(1,-120,0,20)
    DropBtn.Font=Enum.Font.GothamMedium
    DropBtn.Text=countSelected().."/"..#itemList.." selected ▾"
    DropBtn.TextColor3=Theme.TextPrimary
    DropBtn.TextSize=10
    DropBtn.BorderSizePixel=0
    AddCorner(DropBtn,4)
    AddStroke(DropBtn,Theme.Border,1)

    local function RefreshBtn()
        DropBtn.Text=countSelected().."/"..#itemList.." selected ▾"
    end

    DropBtn.MouseButton1Click:Connect(function()
        local existing=Main:FindFirstChild("PH_DD_"..labelText)
        if existing then existing:Destroy(); return end

        local absPos=DropBtn.AbsolutePosition
        local mainPos=Main.AbsolutePosition
        local relX=absPos.X-mainPos.X
        local relY=absPos.Y-mainPos.Y+22
        local listH=math.min(#itemList*24+30,190)

        local Float=Instance.new("Frame",Main)
        Float.Name="PH_DD_"..labelText
        Float.BackgroundColor3=Theme.Header
        Float.BorderSizePixel=0
        Float.Size=UDim2.new(0,185,0,listH)
        Float.Position=UDim2.new(0,relX,0,relY)
        Float.ZIndex=200
        Float.ClipsDescendants=true
        AddCorner(Float,6)
        AddStroke(Float,Theme.Accent,1.5)

        local Scroll=Instance.new("ScrollingFrame",Float)
        Scroll.BackgroundTransparency=1
        Scroll.Size=UDim2.new(1,0,1,-26)
        Scroll.Position=UDim2.new(0,0,0,0)
        Scroll.ScrollBarThickness=3
        Scroll.ScrollBarImageColor3=Theme.Accent
        Scroll.CanvasSize=UDim2.new(0,0,0,0)
        Scroll.AutomaticCanvasSize=Enum.AutomaticSize.Y
        Scroll.ZIndex=201
        AddPad(Scroll,3)
        local slay=Instance.new("UIListLayout",Scroll)
        slay.Padding=UDim.new(0,2)

        for _,name in ipairs(itemList) do
            local on=selectedItems[name]
            local row=Instance.new("TextButton",Scroll)
            row.BackgroundColor3=on and Theme.Accent or Theme.Input
            row.BackgroundTransparency=on and 0.6 or 0.1
            row.Size=UDim2.new(1,0,0,22)
            row.BorderSizePixel=0
            row.Font=Enum.Font.GothamMedium
            row.Text=(on and "✓ " or "  ")..name
            row.TextColor3=Theme.TextPrimary
            row.TextSize=10
            row.TextXAlignment=Enum.TextXAlignment.Left
            row.ZIndex=202
            AddCorner(row,4)
            row.MouseButton1Click:Connect(function()
                selectedItems[name]=not selectedItems[name]
                local nowOn=selectedItems[name]
                row.Text=(nowOn and "✓ " or "  ")..name
                TweenService:Create(row,TweenInfo.new(0.12),{
                    BackgroundColor3=nowOn and Theme.Accent or Theme.Input,
                    BackgroundTransparency=nowOn and 0.6 or 0.1
                }):Play()
                RefreshBtn()
                if onChanged then onChanged(selectedItems) end
            end)
        end

        local CloseF=Instance.new("TextButton",Float)
        CloseF.BackgroundColor3=Theme.Border
        CloseF.BackgroundTransparency=0.3
        CloseF.Position=UDim2.new(0,0,1,-26)
        CloseF.Size=UDim2.new(1,0,0,26)
        CloseF.Font=Enum.Font.GothamBold
        CloseF.Text="Tutup"
        CloseF.TextColor3=Theme.TextSecond
        CloseF.TextSize=10
        CloseF.ZIndex=202
        CloseF.MouseButton1Click:Connect(function() Float:Destroy() end)
    end)

    return Frame, RefreshBtn
end

