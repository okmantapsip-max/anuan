-- ============================================================
local function FetchFishAttributes(item)
    local w, m = "Unknown", "Normal"
    for i = 1, 10 do
        w = item:GetAttribute("Weight")
            or (item:FindFirstChild("Weight") and item.Weight.Value)
            or w
        m = item:GetAttribute("Mutation")
            or (item:FindFirstChild("Mutation") and item.Mutation.Value)
            or m
        if w ~= "Unknown" then break end
        task.wait(0.1)
    end
    if type(w) == "number" then
        w = string.format("%.2f kg", w)
    end
    return w, m
end

