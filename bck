-- // UTILS //
local function isScript(obj)
    return obj:IsA("Script") or obj:IsA("LocalScript") or obj:IsA("ModuleScript")
end

local function hasChildren(obj)
    return #obj:GetChildren() > 0
end

local function getIcon(obj)
    if obj:IsA("ModuleScript") then return "📦"
    elseif obj:IsA("LocalScript") then return "📜"
    elseif obj:IsA("Script") then return "📄"
    elseif obj:IsA("Model") then return "🗂️"
    elseif obj:IsA("Tool") then return "🔧"
    elseif obj:IsA("Folder") then return "📁"
    elseif obj:IsA("Frame") or obj:IsA("ScreenGui") then return "🖼️"
    elseif hasChildren(obj) then return "📂"
    else return "▪️"
    end
end

