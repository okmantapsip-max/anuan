-- ========== SEND WEBHOOK ==========
local function SendWebhook(fishName, playerName, userId)
    local fishData = FishDatabase[fishName]

    -- Pakai proxy biar gambar bisa muncul di Discord
    local fishImg = fishData and (PROXY .. "/asset/" .. fishData.assetId) or nil
    local avatarUrl = PROXY .. "/avatar/" .. tostring(userId)

    local embed = {
        title = "🚨 SECRET FISH DETECTED!",
        color = 16768768,
        fields = {
            { name = "Pemain", value = "**" .. playerName .. "**", inline = true },
            { name = "Ikan",   value = "**" .. fishName .. "**",   inline = true },
        },
        footer = { text = "BLOX Gank Webhook | " .. os.date("%X") },
        timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ"),
        thumbnail = { url = avatarUrl },
    }
    if fishImg then embed.image = { url = fishImg } end

    local requestFunc = (syn and syn.request) or (http and http.request) or http_request or request
    if not requestFunc then return false end

    local ok, res = pcall(function()
        return requestFunc({
            Url = WEBHOOK_URL,
            Method = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body = HttpService:JSONEncode({ embeds = { embed } })
        })
    end)
    return ok and res and (res.Success or res.StatusCode == 204)
end

