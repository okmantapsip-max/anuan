-- // RENDER LIST //
local function updateSelectedLabel()
    local count = 0
    for _ in pairs(selectedScripts) do count = count + 1 end
    selectedLabel.Text = count .. " dipilih"
end

local function renderList(parent)
    for _, c in ipairs(listFrame:GetChildren()) do
        if c:IsA("Frame") then c:Destroy() end
    end

    local items = {}
    if parent == game then
        for _, root in ipairs(ROOTS) do table.insert(items, root.obj) end
    else
        for _, child in ipairs(parent:GetChildren()) do
            table.insert(items, child)
        end
    end

    for _, obj in ipairs(items) do
        local row = Instance.new("Frame")
        row.Size = UDim2.new(1, 0, 0, 30)
        row.BackgroundColor3 = selectedScripts[obj] and Color3.fromRGB(25,45,30) or Color3.fromRGB(28, 28, 40)
        row.BorderSizePixel = 0
        row.Parent = listFrame
        Instance.new("UICorner", row).CornerRadius = UDim.new(0, 5)

        -- Checkbox
        local checkbox = Instance.new("TextButton")
        checkbox.Size = UDim2.new(0, 20, 0, 20)
        checkbox.Position = UDim2.new(0, 5, 0.5, -10)
        checkbox.BorderSizePixel = 0
        checkbox.Font = Enum.Font.GothamBold
        checkbox.TextSize = 11
        checkbox.TextColor3 = Color3.fromRGB(255, 255, 255)
        checkbox.Parent = row
        Instance.new("UICorner", checkbox).CornerRadius = UDim.new(0, 4)

        if isScript(obj) then
            local checked = selectedScripts[obj] == true
            checkbox.Text = checked and "✓" or ""
            checkbox.BackgroundColor3 = checked and Color3.fromRGB(0, 160, 80) or Color3.fromRGB(45, 45, 65)

            checkbox.MouseButton1Click:Connect(function()
                if selectedScripts[obj] then
                    selectedScripts[obj] = nil
                    checkbox.Text = ""
                    checkbox.BackgroundColor3 = Color3.fromRGB(45, 45, 65)
                    row.BackgroundColor3 = Color3.fromRGB(28, 28, 40)
                else
                    selectedScripts[obj] = true
                    checkbox.Text = "✓"
                    checkbox.BackgroundColor3 = Color3.fromRGB(0, 160, 80)
                    row.BackgroundColor3 = Color3.fromRGB(25, 45, 30)
                end
                updateSelectedLabel()
            end)
        else
            checkbox.Text = ""
            checkbox.BackgroundColor3 = Color3.fromRGB(32, 32, 45)
            checkbox.Active = false
            checkbox.AutoButtonColor = false
        end

        -- Name button
        local nameBtn = Instance.new("TextButton")
        nameBtn.Size = UDim2.new(1, -90, 1, 0)
        nameBtn.Position = UDim2.new(0, 30, 0, 0)
        nameBtn.BackgroundTransparency = 1
        nameBtn.TextColor3 = isScript(obj) and Color3.fromRGB(140, 210, 255) or Color3.fromRGB(200, 200, 200)
        nameBtn.Font = Enum.Font.Gotham
        nameBtn.TextSize = 11
        nameBtn.TextXAlignment = Enum.TextXAlignment.Left
        nameBtn.Text = getIcon(obj) .. " " .. obj.Name
        nameBtn.TextTruncate = Enum.TextTruncate.AtEnd
        nameBtn.Parent = row

        -- Class badge
        local badge = Instance.new("TextLabel")
        badge.Size = UDim2.new(0, 82, 0, 16)
        badge.Position = UDim2.new(1, -88, 0.5, -8)
        badge.BackgroundColor3 = Color3.fromRGB(35, 35, 52)
        badge.TextColor3 = Color3.fromRGB(110, 110, 150)
        badge.Font = Enum.Font.Gotham
        badge.TextSize = 8
        badge.Text = obj.ClassName
        badge.TextTruncate = Enum.TextTruncate.AtEnd
        badge.Parent = row
        Instance.new("UICorner", badge).CornerRadius = UDim.new(0, 3)

        if hasChildren(obj) then
            nameBtn.MouseButton1Click:Connect(function()
                table.insert(currentPath, parent)
                currentParent = obj
                local parts = {}
                for _, p in ipairs(currentPath) do
                    table.insert(parts, p == game and "game" or p.Name)
                end
                table.insert(parts, obj.Name)
                breadLabel.Text = table.concat(parts, " › ")
                renderList(obj)
            end)
            local arrow = Instance.new("TextLabel")
            arrow.Size = UDim2.new(0, 10, 1, 0)
            arrow.Position = UDim2.new(1, -12, 0, 0)
            arrow.BackgroundTransparency = 1
            arrow.Text = "›"
            arrow.TextColor3 = Color3.fromRGB(90, 90, 130)
            arrow.Font = Enum.Font.GothamBold
            arrow.TextSize = 14
            arrow.Parent = row
        end

        row.MouseEnter:Connect(function()
            if not selectedScripts[obj] then
                TweenService:Create(row, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(35, 35, 52)}):Play()
            end
        end)
        row.MouseLeave:Connect(function()
            if not selectedScripts[obj] then
                TweenService:Create(row, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(28, 28, 40)}):Play()
            end
        end)
    end

    listLayout:ApplyLayout()
    listFrame.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 6)
end

-- // BACK //
backBtn.MouseButton1Click:Connect(function()
    if #currentPath == 0 then return end
    local prev = table.remove(currentPath)
    currentParent = prev
    if #currentPath == 0 then
        breadLabel.Text = "game"
    else
        local parts = {}
        for _, p in ipairs(currentPath) do
            table.insert(parts, p == game and "game" or p.Name)
        end
        table.insert(parts, prev == game and "game" or prev.Name)
        breadLabel.Text = table.concat(parts, " › ")
    end
    renderList(prev)
end)

-- // SELECT ALL //
selectAllBtn.MouseButton1Click:Connect(function()
    local children = currentParent == game and (function()
        local t = {} for _, r in ipairs(ROOTS) do table.insert(t, r.obj) end return t
    end)() or currentParent:GetChildren()

    local allSelected = true
    for _, obj in ipairs(children) do
        if isScript(obj) and not selectedScripts[obj] then allSelected = false break end
    end
    for _, obj in ipairs(children) do
        if isScript(obj) then
            selectedScripts[obj] = allSelected and nil or true
        end
    end
    updateSelectedLabel()
    renderList(currentParent)
end)

-- // CLEAR //
clearBtn.MouseButton1Click:Connect(function()
    selectedScripts = {}
    updateSelectedLabel()
    renderList(currentParent)
end)

-- // DOWNLOAD //
downloadBtn.MouseButton1Click:Connect(function()
    local count = 0
    for _ in pairs(selectedScripts) do count = count + 1 end
    if count == 0 then
        statusLabel.Text = "⚠ Belum ada yang dipilih!"
        return
    end

    statusLabel.Text = "⏳ Mendownload..."
    local downloaded, failed = 0, 0

    for obj in pairs(selectedScripts) do
        pcall(function()
            local source = obj.Source
            if source and source ~= "" then
                local ext = obj:IsA("ModuleScript") and ".module.lua" or ".lua"
                local parentName = obj.Parent and obj.Parent.Name or "unknown"
                local filename = (parentName .. "_" .. obj.Name .. ext):gsub("[^%w%._%-]", "_")
                writefile(filename, source)
                downloaded = downloaded + 1
            else
                failed = failed + 1
            end
        end)
    end

    local msg = "✅ " .. downloaded .. " file tersimpan"
    if failed > 0 then msg = msg .. "\n⚠ " .. failed .. " locked (skip)" end
    statusLabel.Text = msg
    downloadBtn.Text = "✅ Done!"
    task.wait(3)
    downloadBtn.Text = "⬇ Download Selected"
end)

