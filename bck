-- // RENDER LIST //
local function updateSelectedLabel()
    local count = 0
    for _ in pairs(selectedScripts) do count = count + 1 end
    selectedLabel.Text = count .. " dipilih"
end

local function renderList(parent)
    -- clear existing
    for _, c in ipairs(listFrame:GetChildren()) do
        if c:IsA("Frame") then c:Destroy() end
    end

    local items = {}

    -- kalau di root (game), tampilkan ROOTS
    if parent == game then
        for _, root in ipairs(ROOTS) do
            table.insert(items, root.obj)
        end
    else
        for _, child in ipairs(parent:GetChildren()) do
            table.insert(items, child)
        end
    end

    for _, obj in ipairs(items) do
        local row = Instance.new("Frame")
        row.Size = UDim2.new(1, 0, 0, 34)
        row.BackgroundColor3 = Color3.fromRGB(30, 30, 42)
        row.BorderSizePixel = 0
        row.Parent = listFrame
        Instance.new("UICorner", row).CornerRadius = UDim.new(0, 6)

        -- Checkbox (hanya untuk script)
        local checkbox = Instance.new("TextButton")
        checkbox.Size = UDim2.new(0, 22, 0, 22)
        checkbox.Position = UDim2.new(0, 6, 0.5, -11)
        checkbox.BorderSizePixel = 0
        checkbox.Font = Enum.Font.GothamBold
        checkbox.TextSize = 12
        checkbox.Parent = row

        if isScript(obj) then
            local checked = selectedScripts[obj] == true
            checkbox.Text = checked and "✓" or ""
            checkbox.BackgroundColor3 = checked and Color3.fromRGB(0, 160, 80) or Color3.fromRGB(50, 50, 70)
            checkbox.TextColor3 = Color3.fromRGB(255, 255, 255)
            Instance.new("UICorner", checkbox).CornerRadius = UDim.new(0, 4)

            checkbox.MouseButton1Click:Connect(function()
                if selectedScripts[obj] then
                    selectedScripts[obj] = nil
                    checkbox.Text = ""
                    checkbox.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
                    row.BackgroundColor3 = Color3.fromRGB(30, 30, 42)
                else
                    selectedScripts[obj] = true
                    checkbox.Text = "✓"
                    checkbox.BackgroundColor3 = Color3.fromRGB(0, 160, 80)
                    row.BackgroundColor3 = Color3.fromRGB(25, 45, 30)
                end
                updateSelectedLabel()
            end)
        else
            checkbox.Text = ""
            checkbox.BackgroundColor3 = Color3.fromRGB(35, 35, 48)
            checkbox.TextColor3 = Color3.fromRGB(100, 100, 120)
            Instance.new("UICorner", checkbox).CornerRadius = UDim.new(0, 4)
            checkbox.Active = false
            checkbox.AutoButtonColor = false
        end

        -- Icon + Name
        local nameBtn = Instance.new("TextButton")
        nameBtn.Size = UDim2.new(1, -80, 1, 0)
        nameBtn.Position = UDim2.new(0, 34, 0, 0)
        nameBtn.BackgroundTransparency = 1
        nameBtn.TextColor3 = isScript(obj) and Color3.fromRGB(150, 220, 255) or Color3.fromRGB(210, 210, 210)
        nameBtn.Font = Enum.Font.Gotham
        nameBtn.TextSize = 12
        nameBtn.TextXAlignment = Enum.TextXAlignment.Left
        nameBtn.Text = getIcon(obj) .. " " .. obj.Name
        nameBtn.TextTruncate = Enum.TextTruncate.AtEnd
        nameBtn.Parent = row

        -- ClassName badge
        local classBadge = Instance.new("TextLabel")
        classBadge.Size = UDim2.new(0, 80, 0, 18)
        classBadge.Position = UDim2.new(1, -86, 0.5, -9)
        classBadge.BackgroundColor3 = Color3.fromRGB(40, 40, 58)
        classBadge.TextColor3 = Color3.fromRGB(120, 120, 160)
        classBadge.Font = Enum.Font.Gotham
        classBadge.TextSize = 9
        classBadge.Text = obj.ClassName
        classBadge.TextTruncate = Enum.TextTruncate.AtEnd
        classBadge.Parent = row
        Instance.new("UICorner", classBadge).CornerRadius = UDim.new(0, 4)

        -- Navigate into (kalau punya children)
        if hasChildren(obj) then
            nameBtn.MouseButton1Click:Connect(function()
                table.insert(currentPath, parent)
                currentParent = obj
                -- update breadcrumb
                local parts = {}
                for _, p in ipairs(currentPath) do
                    table.insert(parts, p == game and "game" or p.Name)
                end
                table.insert(parts, obj.Name)
                breadLabel.Text = table.concat(parts, " › ")
                renderList(obj)
            end)
            -- Arrow indicator
            local arrow = Instance.new("TextLabel")
            arrow.Size = UDim2.new(0, 12, 1, 0)
            arrow.Position = UDim2.new(1, -14, 0, 0)
            arrow.BackgroundTransparency = 1
            arrow.Text = "›"
            arrow.TextColor3 = Color3.fromRGB(100, 100, 140)
            arrow.Font = Enum.Font.GothamBold
            arrow.TextSize = 16
            arrow.Parent = row
        end

        -- Hover
        row.MouseEnter:Connect(function()
            if not selectedScripts[obj] then
                TweenService:Create(row, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(38, 38, 55)}):Play()
            end
        end)
        row.MouseLeave:Connect(function()
            if not selectedScripts[obj] then
                TweenService:Create(row, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(30, 30, 42)}):Play()
            end
        end)
    end

    -- update canvas size
    listLayout:ApplyLayout()
    listFrame.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 8)
end

-- // BACK BUTTON //
backBtn.MouseButton1Click:Connect(function()
    if #currentPath == 0 then return end
    local prev = table.remove(currentPath)
    currentParent = prev
    if #currentPath == 0 then
        breadLabel.Text = "game"
    else
        local parts = {}
        for _, p in ipairs(currentPath) do
            table.insert(parts, p == game and "game" or p.Name)
        end
        table.insert(parts, prev == game and "game" or prev.Name)
        breadLabel.Text = table.concat(parts, " › ")
    end
    renderList(prev)
end)

-- // SELECT ALL SCRIPTS IN CURRENT VIEW //
selectAllBtn.MouseButton1Click:Connect(function()
    local children = currentParent == game and (function()
        local t = {}
        for _, r in ipairs(ROOTS) do table.insert(t, r.obj) end
        return t
    end)() or currentParent:GetChildren()

    local allSelected = true
    for _, obj in ipairs(children) do
        if isScript(obj) and not selectedScripts[obj] then
            allSelected = false
            break
        end
    end

    for _, obj in ipairs(children) do
        if isScript(obj) then
            if allSelected then
                selectedScripts[obj] = nil
            else
                selectedScripts[obj] = true
            end
        end
    end

    updateSelectedLabel()
    renderList(currentParent)
end)

-- // CLEAR SELECTION //
clearBtn.MouseButton1Click:Connect(function()
    selectedScripts = {}
    updateSelectedLabel()
    renderList(currentParent)
end)

-- // DOWNLOAD //
downloadBtn.MouseButton1Click:Connect(function()
    local count = 0
    for _ in pairs(selectedScripts) do count = count + 1 end
    if count == 0 then
        downloadBtn.Text = "⚠ Pilih dulu!"
        task.wait(1.5)
        downloadBtn.Text = "⬇ Download Selected"
        return
    end

    local downloaded = 0
    local failed = 0

    for obj in pairs(selectedScripts) do
        pcall(function()
            local source = obj.Source
            if source and source ~= "" then
                local ext = obj:IsA("ModuleScript") and ".module.lua" or ".lua"
                local filename = obj.Parent and (obj.Parent.Name .. "_" .. obj.Name .. ext) or (obj.Name .. ext)
                -- sanitize filename
                filename = filename:gsub("[^%w%._%-]", "_")
                writefile(filename, source)
                downloaded = downloaded + 1
            else
                failed = failed + 1
            end
        end)
    end

    downloadBtn.Text = "✅ " .. downloaded .. " saved" .. (failed > 0 and (" | ⚠ " .. failed .. " locked") or "")
    task.wait(3)
    downloadBtn.Text = "⬇ Download Selected"
end)

